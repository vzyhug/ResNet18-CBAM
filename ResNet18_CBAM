"output_type":"stream"},{"name":"stdout","text":"✅ Epoch 24 - Val Acc: 99.44% | Val Loss: 0.0167\nEarlyStopping counter: 4 / 5\n","output_type":"stream"},{"name":"stderr","text":"Epoch 25/30 [Train]: 100%|██████████| 625/625 [01:41<00:00,  6.17it/s, acc=95.69%]\n","output_type":"stream"},{"name":"stdout","text":"✅ Epoch 25 - Val Acc: 99.32% | Val Loss: 0.0165\nEarlyStopping counter: 5 / 5\n","output_type":"stream"}],"execution_count":5},{"cell_type":"code","source":"Đánh giá trên tập Test độc lập","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# Load trọng số tốt nhất\nmodel.load_state_dict(torch.load('/kaggle/working/best_resnet18_cbam.pt'))\nmodel.eval()\n\ntest_loss, correct_test, total_test = 0.0, 0, 0\n\nprint(\"🔍 Đang đánh giá trên tập Test...\")\nwith torch.no_grad():\n    for inputs, labels in test_loader:\n        inputs, labels = inputs.to(device), labels.to(device)\n        outputs = model(inputs)\n        loss = criterion(outputs, labels)\n        test_loss += loss.item() * inputs.size(0)\n        \n        _, predicted = outputs.max(1)\n        total_test += labels.size(0)\n        correct_test += predicted.eq(labels).sum().item()\n\nprint(f'--- KẾT QUẢ TẬP TEST CHÍNH THỨC ---')\nprint(f'Test Loss: {test_loss / len(test_data):.4f}')\nprint(f'Test Accuracy: {(correct_test / total_test)*100:.2f}%')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T09:58:30.695011Z","iopub.execute_input":"2026-04-17T09:58:30.695894Z","iopub.status.idle":"2026-04-17T09:58:39.214520Z","shell.execute_reply.started":"2026-04-17T09:58:30.695857Z","shell.execute_reply":"2026-04-17T09:58:39.213482Z"}},"outputs":[{"name":"stdout","text":"🔍 Đang đánh giá trên tập Test...\n--- KẾT QUẢ TẬP TEST CHÍNH THỨC ---\nTest Loss: 0.0314\nTest Accuracy: 98.76%\n","output_type":"stream"}],"execution_count":6},{"cell_type":"code","source":"Công cụ Grad-CAM (Vẽ Heatmap)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"class GradCAM:\n    def __init__(self, model, target_layer):\n        self.model = model\n        self.target_layer = target_layer\n        self.gradients = None\n        self.activations = None\n        \n        target_layer.register_forward_hook(self.save_activation)\n        target_layer.register_full_backward_hook(self.save_gradient)\n\n    def save_activation(self, module, input, output):\n        self.activations = output.detach()\n\n    def save_gradient(self, module, grad_input, grad_output):\n        self.gradients = grad_output[0].detach()\n\n    def generate(self, input_tensor, class_idx=None):\n        self.model.eval()\n        self.model.zero_grad()\n        \n        output = self.model(input_tensor)\n        if class_idx is None:\n            class_idx = output.argmax(dim=1).item()\n            \n        loss = output[0, class_idx]\n        loss.backward()\n\n        weights = torch.mean(self.gradients, dim=[2, 3], keepdim=True)\n        cam = torch.sum(weights * self.activations, dim=1).squeeze()\n        cam = F.relu(cam)\n        cam = cam - cam.min()\n        cam = cam / (cam.max() + 1e-8)\n        \n        return cam.cpu().numpy(), class_idx\n\ndef show_cam_on_image(img_path, cam_extractor):\n    original_img = Image.open(img_path).convert('RGB')\n    input_tensor = val_test_transforms(original_img).unsqueeze(0).to(device)\n    \n    heatmap, pred_idx = cam_extractor.generate(input_tensor)\n    heatmap = cv2.resize(heatmap, (224, 224))\n    heatmap = np.uint8(255 * heatmap)\n    heatmap = cv2.applyColorMap(heatmap, cv2.COLORMAP_JET)\n    \n    img_cropped = transforms.CenterCrop(224)(transforms.Resize(256)(original_img))\n    img_cv = cv2.cvtColor(np.array(img_cropped), cv2.COLOR_RGB2BGR)\n    img_cv = np.float32(img_cv) / 255\n    heatmap_float = np.float32(heatmap) / 255\n    \n    cam_result = heatmap_float * 0.4 + img_cv * 0.6\n    cam_result = cam_result / np.max(cam_result)\n    \n    fig, ax = plt.subplots(1, 2, figsize=(10, 5))\n    ax[0].imshow(img_cropped)\n    ax[0].set_title(\"Ảnh Gốc\")\n    ax[0].axis('off')\n    \n    ax[1].imshow(cv2.cvtColor(np.uint8(255 * cam_result), cv2.COLOR_BGR2RGB))\n    \n    # Label mapping của ImageFolder sẽ theo thứ tự AlphaBetic: Cat=0, Dog=1\n    class_name = \"Chó (Dog)\" if pred_idx == 1 else \"Mèo (Cat)\" \n    ax[1].set_title(f\"Grad-CAM - AI Dự đoán: {class_name}\")\n    ax[1].axis('off')\n    plt.tight_layout()\n    plt.show()\n\n# Chọn layer Spatial Attention cuối cùng làm mục tiêu để vẽ Heatmap\ncam_extractor = GradCAM(model, target_layer=model.cbam.sa.conv1)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T09:58:43.188217Z","iopub.execute_input":"2026-04-17T09:58:43.189222Z","iopub.status.idle":"2026-04-17T09:58:43.200457Z","shell.execute_reply.started":"2026-04-17T09:58:43.189171Z","shell.execute_reply":"2026-04-17T09:58:43.199777Z"}},"outputs":[],"execution_count":7},{"cell_type":"code","source":"Chạy và Trải nghiệm Heatmap AI","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import os\nimport glob\nimport random\nimport cv2\nimport numpy as np\nimport matplotlib.pyplot as plt\nfrom PIL import Image\nimport torch\nimport torch.nn.functional as F\nimport torchvision.transforms as transforms\n\n# --- NÂNG CẤP HÀM HIỂN THỊ: 3 ẢNH CẠNH NHAU (SIDE-BY-SIDE) ---\ndef show_cam_and_bbox_on_image(img_path, cam_extractor, threshold=0.5):\n    # 1. Tải và Tiền xử lý ảnh\n    original_img = Image.open(img_path).convert('RGB')\n    \n    # Sử dụng đúng transform của tập Val/Test để đồng nhất kích thước\n    img_tensor = val_test_transforms(original_img).unsqueeze(0).to(device)\n    \n    # Chuẩn bị ảnh display (đã qua CenterCrop 224)\n    img_display = transforms.CenterCrop(224)(transforms.Resize(256)(original_img))\n    img_cv_bgr = cv2.cvtColor(np.array(img_display), cv2.COLOR_RGB2BGR)\n    img_float = np.float32(img_cv_bgr) / 255\n\n    # 2. Sinh Heatmap (Grad-CAM)\n    model.eval()\n    # Không dùng torch.no_grad() ở đây vì Grad-CAM cần tính Gradient\n    output = model(img_tensor)\n    probabilities = F.softmax(output[0], dim=0)\n    conf, pred_idx = torch.max(probabilities, dim=0)\n    \n    # Tính toán CAM\n    heatmap_raw, _ = cam_extractor.generate(img_tensor, class_idx=pred_idx)\n    heatmap_resized = cv2.resize(heatmap_raw, (224, 224))\n    \n    heatmap_color = np.uint8(255 * heatmap_resized)\n    heatmap_color = cv2.applyColorMap(heatmap_color, cv2.COLORMAP_JET)\n    heatmap_float = np.float32(heatmap_color) / 255\n\n    # Trộn ảnh gốc và heatmap\n    cam_result = heatmap_float * 0.4 + img_float * 0.6\n    cam_result = cam_result / np.max(cam_result)\n    cam_result_rgb = cv2.cvtColor(np.uint8(255 * cam_result), cv2.COLOR_BGR2RGB)\n    \n    # 3. Tạo Bounding Box\n    mask = np.where(heatmap_resized > threshold, 255, 0).astype(np.uint8)\n    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    \n    img_bbox = img_cv_bgr.copy()\n    bbox_info = \"Không tìm thấy vùng đặc trưng đủ mạnh\"\n    if len(contours) > 0:\n        c = max(contours, key=cv2.contourArea)\n        x, y, w, h = cv2.boundingRect(c)\n        cv2.rectangle(img_bbox, (x, y), (x + w, y + h), (0, 255, 0), 2)\n        bbox_info = f\"BBox: [{w}x{h}] tại ({x},{y})\"\n\n    # 4. Hiển thị\n    class_names = [\"Mèo (Cat)\", \"Chó (Dog)\"]\n    predicted_label = class_names[pred_idx.item()]\n    \n    fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n    axes[0].imshow(img_display)\n    axes[0].set_title(\"1. Ảnh Gốc (Crop)\")\n    axes[0].axis('off')\n\n    axes[1].imshow(cam_result_rgb)\n    axes[1].set_title(f\"2. Heatmap (Grad-CAM)\")\n    axes[1].axis('off')\n\n    axes[2].imshow(cv2.cvtColor(img_bbox, cv2.COLOR_BGR2RGB))\n    axes[2].set_title(f\"3. Bounding Box (Thresh: {threshold})\")\n    axes[2].axis('off')\n\n    plt.suptitle(f\"Dự đoán: {predicted_label} ({conf.item()*100:.2f}%)\\n{bbox_info}\", \n                 fontsize=14, fontweight='bold', y=1.05)\n    plt.tight_layout()\n    plt.show()\n\n# ==============================================================\n# KHỐI CHẠY THỬ NGHIỆM (LẤY ẢNH TỪ TẬP TEST MỚI)\n# ==============================================================\n\n# Lấy đường dẫn ảnh từ tập TEST (Thư mục bạn đã chuẩn bị)\ncat_test_dir = os.path.join(base_path, 'test/cat')\ndog_test_dir = os.path.join(base_path, 'test/dog')\n\ncat_test_paths = glob.glob(os.path.join(cat_test_dir, '*.jpg'))\ndog_test_paths = glob.glob(os.path.join(dog_test_dir, '*.jpg'))\n\nif len(cat_test_paths) == 0 or len(dog_test_paths) == 0:\n    print(\"❌ LỖI: Không tìm thấy ảnh trong thư mục Test. Kiểm tra lại base_path!\")\nelse:\n    # Chọn ngẫu nhiên 1 ảnh mèo và 1 ảnh chó\n    sample_cat = random.choice(cat_test_paths)\n    sample_dog = random.choice(dog_test_paths)\n\n    print(\"==== PHÂN TÍCH ĐẶC TRƯNG MÈO ====\")\n    show_cam_and_bbox_on_image(sample_cat, cam_extractor, threshold=0.5)\n\n    print(\"==== PHÂN TÍCH ĐẶC TRƯNG CHÓ ====\")\n    show_cam_and_bbox_on_image(sample_dog, cam_extractor, threshold=0.5)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T09:59:32.581898Z","iopub.execute_input":"2026-04-17T09:59:32.582407Z","iopub.status.idle":"2026-04-17T09:59:33.427863Z","shell.execute_reply.started":"2026-04-17T09:59:32.582374Z","shell.execute_reply":"2026-04-17T09:59:33.427248Z"}},"outputs":[{"name":"stdout","text":"==== PHÂN TÍCH ĐẶC TRƯNG MÈO ====\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1500x500 with 3 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"==== PHÂN TÍCH ĐẶC TRƯNG CHÓ ====\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1500x500 with 3 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":12},{"cell_type":"code","source":"Đánh giá chi tiết mô hình trên tập Test","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import torch\nimport torch.nn.functional as F\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.metrics import confusion_matrix, classification_report, roc_curve, auc\nfrom tqdm import tqdm\nimport sys\n\n# Đảm bảo model đang ở chế độ đánh giá và dùng đúng trọng số\nmodel.load_state_dict(torch.load('/kaggle/working/best_resnet18_cbam.pt'))\nmodel.eval()\n\nall_preds, all_labels, all_probs = [], [], []\ntest_loss = 0.0\n\nprint(f\"🔍 Đang đánh giá thực tế trên {len(test_data)} ảnh...\")\n\nwith torch.no_grad():\n    for inputs, labels in tqdm(test_loader, desc=\"Testing\"):\n        inputs, labels = inputs.to(device), labels.to(device)\n        outputs = model(inputs)\n        \n        loss = criterion(outputs, labels)\n        test_loss += loss.item() * inputs.size(0)\n        \n        _, preds = torch.max(outputs, 1)\n        probs = F.softmax(outputs, dim=1)[:, 1]\n        \n        all_preds.extend(preds.cpu().numpy())\n        all_labels.extend(labels.cpu().numpy())\n        all_probs.extend(probs.cpu().numpy())\n\n# Tính toán các chỉ số\navg_test_loss = test_loss / len(test_data)\ntest_accuracy = np.sum(np.array(all_preds) == np.array(all_labels)) / len(test_data)\n\nprint(f\"\\n🏆 Test Accuracy THẬT: {test_accuracy * 100:.2f}%\")\n\n# Vẽ biểu đồ\ncm = confusion_matrix(all_labels, all_preds)\nclass_names = [\"Mèo (Cat)\", \"Chó (Dog)\"]\n\nfig, axes = plt.subplots(1, 2, figsize=(16, 6))\n\n# Heatmap với định dạng số nguyên chuẩn\nsns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[0],\n            xticklabels=class_names, yticklabels=class_names)\naxes[0].set_title('Ma Trận Nhầm Lẫn')\n\n# ROC Curve\nfpr, tpr, _ = roc_curve(all_labels, all_probs)\naxes[1].plot(fpr, tpr, label=f'AUC = {auc(fpr, tpr):.3f}', color='red')\naxes[1].plot([0, 1], [0, 1], linestyle='--')\naxes[1].set_title('Biểu đồ ROC')\nplt.legend()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T09:59:39.275602Z","iopub.execute_input":"2026-04-17T09:59:39.275882Z","iopub.status.idle":"2026-04-17T09:59:48.998999Z","shell.execute_reply.started":"2026-04-17T09:59:39.275859Z","shell.execute_reply":"2026-04-17T09:59:48.998076Z"}},"outputs":[{"name":"stdout","text":"🔍 Đang đánh giá thực tế trên 2498 ảnh...\n","output_type":"stream"},{"name":"stderr","text":"Testing: 100%|██████████| 79/79 [00:07<00:00, 10.36it/s]\n","output_type":"stream"},{"name":"stdout","text":"\n🏆 Test Accuracy THẬT: 98.76%\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x600 with 3 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":13},{"cell_type":"code","source":"import requests\nfrom PIL import Image\nfrom io import BytesIO\nimport torch.nn.functional as F\n\ndef predict_with_heatmap_from_url(url, model, cam_extractor, class_names=['Mèo (Cat)', 'Chó (Dog)']):\n    try:\n        # 1. Tải ảnh từ URL\n        response = requests.get(url)\n        img_raw = Image.open(BytesIO(response.content)).convert('RGB')\n        \n        # 2. Tiền xử lý để đưa vào Model\n        input_tensor = val_test_transforms(img_raw).unsqueeze(0).to(device)\n        \n        # 3. Dự đoán và lấy xác suất (%)\n        model.eval()\n        # Lưu ý: Không dùng torch.no_grad() ở đây vì Grad-CAM cần backward để tính heatmap\n        output = model(input_tensor)\n        probabilities = F.softmax(output, dim=1) # Chuyển logit thành xác suất [0, 1]\n        conf, pred_idx = torch.max(probabilities, 1)\n        confidence_score = conf.item() * 100 # Chuyển sang đơn vị %\n        \n        # 4. Sinh Heatmap từ Grad-CAM\n        heatmap_raw, _ = cam_extractor.generate(input_tensor, class_idx=pred_idx.item())\n        \n        # 5. Xử lý ảnh để hiển thị (CenterCrop 224 giống tập Val/Test)\n        img_display = transforms.CenterCrop(224)(transforms.Resize(256)(img_raw))\n        img_cv = cv2.cvtColor(np.array(img_display), cv2.COLOR_RGB2BGR)\n        img_float = np.float32(img_cv) / 255\n        \n        # 6. Xử lý Heatmap\n        heatmap_resized = cv2.resize(heatmap_raw, (224, 224))\n        heatmap_color = cv2.applyColorMap(np.uint8(255 * heatmap_resized), cv2.COLORMAP_JET)\n        heatmap_float = np.float32(heatmap_color) / 255\n        \n        # Trộn ảnh gốc và heatmap (tỉ lệ 6:4)\n        cam_result = heatmap_float * 0.4 + img_float * 0.6\n        cam_result = cam_result / np.max(cam_result)\n        cam_result_rgb = cv2.cvtColor(np.uint8(255 * cam_result), cv2.COLOR_BGR2RGB)\n        \n        # 7. Hiển thị kết quả\n        fig, ax = plt.subplots(1, 2, figsize=(12, 6))\n        \n        ax[0].imshow(img_display)\n        ax[0].set_title(\"1. Ảnh Gốc (Đã Crop)\")\n        ax[0].axis('off')\n        \n        ax[1].imshow(cam_result_rgb)\n        # Thêm phần trăm vào tiêu đề\n        ax[1].set_title(f\"2. Heatmap - Dự đoán: {class_names[pred_idx]}\")\n        ax[1].axis('off')\n        \n        # Tiêu đề tổng quát với độ tin cậy cụ thể\n        plt.suptitle(f\"Phân tích ảnh từ Web\\nKết quả: {class_names[pred_idx]} ({confidence_score:.2f}%)\", \n                     fontsize=16, fontweight='bold', color='darkblue')\n        \n        plt.tight_layout()\n        plt.show()\n\n    except Exception as e:\n        print(f\"❌ Lỗi xử lý ảnh từ URL: {e}\")\n\n# --- CHẠY THỬ ---\nurl_test = \"https://theselfishmeme.co.uk/wp-content/uploads/2026/04/anh-avatar-cho-meme-hai-bua-20.webp\" # 1-29 \n#url_test = \"https://theselfishmeme.co.uk/wp-content/uploads/2025/09/meme-cho-nhe-rang-cuoi-10.webp\"  \n\npredict_with_heatmap_from_url(url_test, model, cam_extractor)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-17T10:03:50.524614Z","iopub.execute_input":"2026-04-17T10:03:50.525346Z","iopub.status.idle":"2026-04-17T10:03:51.831977Z","shell.execute_reply.started":"2026-04-17T10:03:50.525311Z","shell.execute_reply":"2026-04-17T10:03:51.831056Z"}},"outputs":[{"output_type":"display_data","dat